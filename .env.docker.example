# ===== بيئة Docker — recruitment.mawazinswift.com =====
# منفذ 80/443 مشغول بالـ nginx المشترك → التطبيق على 8088 داخليًا
#
#   cp .env.docker.example .env
#   docker compose up -d --build
# ثم أضف docker/host-nginx/recruitment.mawazinswift.com.conf للـ nginx المشترك

